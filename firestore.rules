rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Only allow users to read/write their own specific main vault document
    match /vaults/{uid}/items/main {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
    
    // Deny everything else strictly
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
